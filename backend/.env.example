# --- Database (PostgreSQL) ---
# Pooled serverless URLs (Neon, Supabase pooler) often include ?pgbouncer=true&connect_timeout=…
# Standard example (local or managed Postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/relief_db?schema=public"

# --- Auth (use long random values in production; never commit real secrets) ---
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long!!"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long!!"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# --- HTTP ---
PORT=3000
NODE_ENV="development"

# Comma-separated browser origins allowed to call the API with credentials (cookies).
# Production (NODE_ENV=production): must be https:// and required at startup (no localhost).
# Example: https://nezhin.cc or https://nezhin.cc,https://www.nezhin.cc
CORS_ORIGIN="http://localhost:5173"

# Railway / Render / nginx: trust proxy is enabled automatically when NODE_ENV=production.
# Override explicitly if needed:
# TRUST_PROXY="1"

# --- Optional seed overrides (only when running: npx prisma db seed) ---
# Wipes app data and creates one super-admin. Defaults are set in prisma/seed.ts if unset.
# SEED_SUPERADMIN_USERNAME="alihmdn"
# SEED_SUPERADMIN_DISPLAY_NAME="ali hamda"
# SEED_SUPERADMIN_PASSWORD="your-secure-password"
# SEED_SUPERADMIN_EMAIL="you@example.com"
