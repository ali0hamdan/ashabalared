# Browser-visible API origin (no trailing slash). Build-time for Vite.
# Local — must match your backend listen address (see backend PORT in .env):
VITE_API_URL=http://localhost:3000
#
# Production (Railway / HTTPS): required https:// and must not be localhost.
# Example:
# VITE_API_URL=https://ashabalared-production.up.railway.app
